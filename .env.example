PORT=3000
NODE_ENV=development

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=sandcastle_resort

SESSION_SECRET=replace_with_a_long_random_string
APP_URL=http://localhost:3000

# SMTP — leave blank to use Ethereal (free email preview in console, no account needed)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Sandcastle Resort <your@gmail.com>"